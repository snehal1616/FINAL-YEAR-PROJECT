{
  "buildCommand": null,
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/css/(.*)", "destination": "/css/$1" },
    { "source": "/js/(.*)", "destination": "/js/$1" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/(.*).html", "destination": "/$1.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/signup", "destination": "/signup.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/chatbot", "destination": "/chatbot.html" },
    { "source": "/wellness", "destination": "/wellness.html" },
    { "source": "/reports", "destination": "/reports.html" },
    { "source": "/profile", "destination": "/profile.html" },
    { "source": "/", "destination": "/index.html" }
  ]
}
